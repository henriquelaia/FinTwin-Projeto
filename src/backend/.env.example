# ── Base de Dados ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://goldlock:goldlock_dev@postgres:5432/goldlock_db

# ── Cache / Sessões ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT ────────────────────────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=substitui_por_64_chars_aleatorios

# ── Resend (emails transacionais) ──────────────────────────────────────────
# Criar conta em https://resend.com e gerar uma API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Em dev usa onboarding@resend.dev (só funciona para o teu próprio email)
# Em prod usa um domínio verificado: GoldLock <noreply@seudominio.com>
EMAIL_FROM=GoldLock <onboarding@resend.dev>

# ── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Salt Edge (Open Banking) ───────────────────────────────────────────────
SALT_EDGE_APP_ID=
SALT_EDGE_SECRET=
SALT_EDGE_BASE_URL=https://www.saltedge.com/api/v6
SALT_EDGE_WEBHOOK_SECRET=

# ── OpenAI (Assistente Fiscal IA — Sprint 8) ──────────────────────────────
OPENAI_API_KEY=
